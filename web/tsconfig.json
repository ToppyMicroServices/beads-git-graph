{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "lib": ["es2020", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "../media",
    "rootDir": "..",
    "removeComments": true,
    "strict": true,
    "target": "es6"
  }
}
