{
  "compilerOptions": {
    "declaration": true,
    "ignoreDeprecations": "6.0",
    "lib": ["es2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "../out",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "removeComments": true,
    "sourceMap": true,
    "strict": true,
    "target": "es6",
    "types": ["node", "vscode"]
  }
}
